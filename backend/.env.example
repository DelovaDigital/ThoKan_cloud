APP_NAME=ThoKan Cloud API
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=thokan_cloud
POSTGRES_USER=thokan
POSTGRES_PASSWORD=change_me_db_password

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_MIN=5256000
JWT_REFRESH_EXPIRES_DAYS=3650
CSRF_SECRET=change_me_csrf_secret

STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./storage
STORAGE_ENCRYPTION_KEY=change_me_32_plus_chars

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=admin@thokan.com

APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.thokan.cloud
APNS_PRIVATE_KEY=
APNS_USE_SANDBOX=true

RATE_LIMIT_PER_MINUTE=120
