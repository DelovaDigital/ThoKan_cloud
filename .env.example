# Global
APP_NAME=thokan-cloud
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Security
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_MIN=15
JWT_REFRESH_EXPIRES_DAYS=7
CSRF_SECRET=change_me_csrf_secret

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=thokan_cloud
POSTGRES_USER=thokan
POSTGRES_PASSWORD=change_me_db_password

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./storage
STORAGE_HOST_PATH=./storage
STORAGE_ENCRYPTION_KEY=change_me_32_plus_chars

# Optional S3
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=admin@thokan.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Rate limiting
RATE_LIMIT_PER_MINUTE=120
