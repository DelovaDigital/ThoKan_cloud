{
  "name": "thokan-cloud-frontend",
  "version": "1.0.11",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "prebuild": "if [ -f ../scripts/sync_version.py ] && [ -f ../VERSION ]; then python3 ../scripts/sync_version.py; else echo 'Skipping version sync (VERSION/scripts not available in this build context)'; fi",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "capacitor:sync": "cap sync",
    "capacitor:open:ios": "cap open ios",
    "capacitor:open:android": "cap open android",
    "capacitor:build:ios": "next build && cap copy && cap sync ios",
    "capacitor:build:android": "next build && cap copy && cap sync android"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "lucide-react": "0.477.0",
    "next": "^15.5.12",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/ios": "^6.0.0",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "autoprefixer": "10.4.20",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.2"
  }
}
